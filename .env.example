# Copy to .env and adjust. Only the AI copilot needs configuration; the CAD
# engine works with no env at all.
#
# The copilot speaks the OpenAI-compatible chat-completions format. Default is a
# FREE local Ollama (no key). For a keyed provider (Groq / OpenRouter / Gemini's
# OpenAI endpoint / OpenAI), set all three vars below.

# --- Default: local Ollama (free) ---
# Requires Ollama running on the host and a tool-capable model pulled, e.g.:
#   ollama pull qwen2.5
COPILOT_MODEL=qwen2.5
# Ollama host (default shown); only change if Ollama runs elsewhere:
# OLLAMA_HOST=http://host.docker.internal:11434

# --- Keyed OpenAI-compatible provider (uncomment to use instead) ---
# COPILOT_BASE_URL=https://api.groq.com/openai/v1
# COPILOT_API_KEY=sk-...
# COPILOT_MODEL=llama-3.3-70b-versatile
