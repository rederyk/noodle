  {
   "id": "n10",
   "type": "CodeBlock",
   "params": {
    "code": "# DE CASTELJAU: how a Bezier is really built. No polynomial, no formula \u2014 just\n# INTERPOLATION, over and over, until only one point is left.\n#\n#   level 1: walk a fraction t along each of the 3 sides of the control polygon\n#   level 2: join those 3 points, walk t along each of the 2 new sides\n#   level 3: join those 2, walk t along the 1 remaining side -> THE POINT ON THE CURVE\n#\n# Drag t from 0 to 1 and that point sweeps out the whole curve.\nt = 0.4    #@param float min=0 max=1 step=0.005\nP = [in_0, in_1, in_2, in_3]\n\ndef lerp(a, b, s):\n    return a + (b - a) * s          # a fraction s of the way from a to b\n\ndef step(pts, s):\n    return [lerp(pts[i], pts[i + 1], s) for i in range(len(pts) - 1)]\n\nL1 = step(P, t)          # 3 points\nL2 = step(L1, t)         # 2 points\nL3 = step(L2, t)         # 1 point: it lies exactly ON the curve\n# the trace: the same construction repeated for every moment up to t\ntrace = []\nfor i in range(int(t * 200) + 1):\n    s = i / 200\n    q = P\n    while len(q) > 1:\n        q = step(q, s)\n    trace.append(q[0])\nif len(trace) < 2:\n    trace = [P[0], P[0] + Vector(0, 0, 0.05)]     # a polyline wants 2 points\nresult = {\"L1\": L1, \"L2\": L2, \"point\": L3[0], \"trace\": trace, \"t\": t}\n"
   },
