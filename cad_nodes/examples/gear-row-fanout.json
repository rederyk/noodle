      "id": "n5",
      "type": "CodeBlock",
      "params": {
        "code": "# Parametric spur gear. `teeth` is wired from a Range -> the whole block\n# FANS OUT (one gear per value); a matching Range of X positions spreads them.\nimport math\nteeth = 12        #@param int min=6 max=40\nradius = 16.0     #@param min=8 max=40 step=1\nthickness = 5.0   #@param min=2 max=20 step=0.5\nbore = 4.0        #@param min=0 max=14 step=0.5\n\nbody = Cylinder(radius, thickness)\ntooth = Box((2 * math.pi * radius / teeth) * 0.55, radius * 0.36, thickness)\ng = body\nfor i in range(int(teeth)):\n    g += Rot(0, 0, i * 360.0 / teeth) * (Pos(0, radius, 0) * tooth)\nif bore > 0:\n    g -= Cylinder(bore, thickness)\nresult = g\n",
        "_cb": {
          "radius": 18.3111,
          "thickness": 9.5
        }
      },
